# Single .env file for the "single command" Docker Compose startup
# (`npm run docker:up` / `docker compose up -d --build`).
#
# All variables have sane defaults baked into docker-compose.yml, so copying
# this file is optional for local testing — only change values if you need
# something other than the defaults (e.g. a custom JWT secret, different
# ports, or a different CORS origin for the portal).

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lms

# Used by the api container to reach the postgres container over the
# Docker network (service name "postgres", not localhost/127.0.0.1).
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/lms?schema=public

JWT_SECRET=dev-secret-change-me

# Origin the api's CORS policy allows, and the URL baked into the portal's
# build so the browser knows where to send API requests.
CORS_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:3000

# Host ports to expose.
API_PORT=3000
PORTAL_PORT=5173
