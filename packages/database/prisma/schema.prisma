generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TRAINER
  LEARNER
  LD
}

enum TrainingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonContentType {
  TEXT
}

enum PointsActivityType {
  LESSON
  TRAINING
  QUIZ
  LEARNING_PATH
  TRAINING_MILESTONE
  STREAK
}

model User {
  id                    String                 @id @default(cuid())
  username              String                 @unique
  passwordHash          String
  roles                 Role[]
  createdAt             DateTime               @default(now())
  deactivatedAt         DateTime?
  passwordResetTokens   PasswordResetToken[]
  lessonProgress        LessonProgress[]
  authoredTrainings     Training[]             @relation("TrainingAuthor")
  authoredLearningPaths LearningPath[]         @relation("LearningPathAuthor")
  quizAttempts          QuizAttempt[]
  pointsTransactions    PointsTransaction[]
  badges                UserBadge[]
  learningActivityDays  LearningActivityDay[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Training {
  id                  String                 @id @default(cuid())
  title               String
  description         String
  status              TrainingStatus         @default(DRAFT)
  level               String
  language            String
  gamificationEnabled Boolean                @default(true)
  chapters            Chapter[]
  createdAt           DateTime               @default(now())
  createdByUserId     String?
  createdBy           User?                  @relation("TrainingAuthor", fields: [createdByUserId], references: [id])
  quiz                Quiz?
  learningPaths       LearningPathTraining[]
  requiredForBadges   Badge[]
}


model Chapter {
  id         String   @id @default(cuid())
  trainingId String
  training   Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  title      String
  order      Int
  lessons    Lesson[]
}

model Lesson {
  id              String            @id @default(cuid())
  chapterId       String
  chapter         Chapter           @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  title           String
  order           Int
  contentType     LessonContentType @default(TEXT)
  contentBody     String
  lessonProgress  LessonProgress[]
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([userId, lessonId])
}

model Quiz {
  id                     String         @id @default(cuid())
  trainingId             String         @unique
  training               Training       @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  title                  String
  passingScorePercentage Int            @default(70)
  createdAt              DateTime       @default(now())
  questions              QuizQuestion[]
  attempts               QuizAttempt[]
}

model QuizQuestion {
  id      String       @id @default(cuid())
  quizId  String
  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text    String
  order   Int
  options QuizOption[]
}

model QuizOption {
  id         String       @id @default(cuid())
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean      @default(false)
  order      Int
}

model QuizAttempt {
  id              String   @id @default(cuid())
  quizId          String
  quiz            Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  scorePercentage Int
  passed          Boolean
  createdAt       DateTime @default(now())
}

model LearningPath {
  id              String                 @id @default(cuid())
  title           String
  description     String
  status          TrainingStatus         @default(DRAFT)
  createdAt       DateTime               @default(now())
  createdByUserId String?
  createdBy       User?                  @relation("LearningPathAuthor", fields: [createdByUserId], references: [id])
  trainings       LearningPathTraining[]
}

model LearningPathTraining {
  id             String       @id @default(cuid())
  learningPathId String
  learningPath   LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  trainingId     String
  training       Training     @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  order          Int

  @@unique([learningPathId, trainingId])
}

model PointsTransaction {
  id               String             @id @default(cuid())
  userId           String
  user             User               @relation(fields: [userId], references: [id])
  activityType     PointsActivityType
  activityId       String
  ruleCode         String
  ruleVersion      Int                @default(1)
  points           Int
  balanceBefore    Int
  balanceAfter     Int
  awardedAt        DateTime           @default(now())
  correctionReason String?

  @@unique([userId, activityType, activityId, ruleCode, ruleVersion])
}

model Badge {
  id                     String      @id @default(cuid())
  code                   String      @unique
  name                   String
  description            String
  isSkillBadge           Boolean     @default(false)
  requiredTrainingId     String?
  requiredTraining       Training?   @relation(fields: [requiredTrainingId], references: [id])
  minimumScorePercentage Int?
  isActive               Boolean     @default(true)
  createdAt              DateTime    @default(now())
  userBadges             UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id])
  awardedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model LearningActivityDay {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  activityDate DateTime
  createdAt    DateTime @default(now())

  @@unique([userId, activityDate])
}
